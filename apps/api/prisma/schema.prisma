// #14 대화 영속화 스키마.
// 소유자 = 익명 browserId. 캐릭터당 대화 1개 = (browserId, personaId) 유니크 → 이어하기 단위.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String    @id @default(cuid())
  browserId String
  personaId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  @@unique([browserId, personaId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // 'user' | 'model' — DTO(class-validator)에서 강제
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}
