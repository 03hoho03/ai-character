// #14 대화 영속화 스키마.
// 소유자 = 익명 browserId. 캐릭터당 대화 1개 = (browserId, personaId) 유니크 → 이어하기 단위.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// #28 계정 모델. 익명 browserId 탈피의 토대(소유 전환은 #31/#32). 이메일+비번(argon2 해시).
model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())

  // #31 소유 역방향 relation. 실제 소유검증 userId 전환은 #32(이 티켓은 스키마 토대만).
  characters    Character[]
  conversations Conversation[]

  // #43 스토리 모드 소유 역방향 relation(nullable browserId 병행, 소유검증 전환은 #44).
  stories       Story[]
  storySessions StorySession[]
}

model Conversation {
  id        String    @id @default(cuid())
  // #34 browserId nullable — 로그인 전용 생성(#40) 대비. 비로그인은 계속 browserId 운반.
  browserId String?
  personaId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  // #15 장기기억 — 과거 turn 자동 요약과 그 요약에 접힌 선행 turn 수.
  summary         String?
  summarizedCount Int     @default(0)

  // #31 계정 소유(nullable, browserId 병행). 소유검증 전환·유니크키 전환은 #32/#34.
  userId String?
  user   User?   @relation(fields: [userId], references: [id])

  // #34 비로그인 축(browserId) 유지 + 로그인 축(userId) 추가. userId nullable이라
  // Postgres가 NULL을 distinct로 처리 → userId unique는 로그인 row에만 자연 partial 집행.
  @@unique([browserId, personaId])
  @@unique([userId, personaId])
  @@index([userId]) // #31 계정 소유 조회 대비
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // 'user' | 'model' — DTO(class-validator)에서 강제
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// #16 캐릭터 영속화. 소유자 = 익명 browserId. id = 클라이언트 제공(`usr-<uuid>`) → #21 로컬→DB 이전이 id 충돌 없이 이뤄진다.
// 구조화 필드(exampleDialogue/prohibitions)는 Json — Persona 형태를 그대로 보존(정규화 이득 없음).
model Character {
  id              String   @id // 클라이언트 제공 usr-<uuid>
  // #32 OwnerContext 전환: 로그인 캐릭터는 userId 소유(browserId 없음) → nullable. 비로그인은 browserId 소유.
  browserId       String?
  name            String
  tagline         String
  personality     String
  speechStyle     String
  worldview       String
  greeting        String
  exampleDialogue Json // ExampleDialogueTurn[] — { user, model }
  prohibitions    Json? // string[] | null
  isPublic        Boolean  @default(false)
  // #25 발견 필터용 분류 메타데이터(프롬프트 미주입). category=단일, tags=다중(Postgres 스칼라 배열).
  category        String?
  tags            String[] @default([])
  // #26 콘텐츠 등급 — 'all'(일반) | 'adult'(성인). 공개목록 기본은 일반만 노출, 성인은 opt-in.
  contentRating   String   @default("all")
  // #31 계정 소유(nullable, browserId 병행). 소유검증 전환은 #32.
  userId          String?
  user            User?    @relation(fields: [userId], references: [id])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([browserId]) // 내 캐릭터 목록
  @@index([userId]) // #31 계정 소유 캐릭터 목록 대비
  @@index([isPublic, updatedAt]) // 공개 캐릭터 목록(최신순)
  @@index([isPublic, category]) // #25 공개+카테고리 필터
  @@index([isPublic, contentRating]) // #26 공개+등급 필터
  @@index([tags], type: Gin) // #25 tags has 필터(배열 포함 검색)
}

// ============================================================================
// #43 스토리 모드(인터랙티브 픽션) 토대. 설계: docs/story-mode-design.md.
// 중심축 = StartSetting. 스탯·엔딩이 시작설정별로 스코프된다.
// 잠긴 결정(sprint-pm Phase 5): Stat=정규화 테이블 / Ending.condition·statValues·
// developmentExamples·suggestedReplies·shortcuts=Json / ownerContext=Character 이중축 복제.
// ============================================================================

model Story {
  id                  String  @id @default(cuid())
  profileImage        String?
  name                String
  tagline             String
  // 스토리 설정 탭. 프롬프트 템플릿 선택 + 세계관/설정/등장인물 정보.
  promptTemplateId    String?
  storyInfo           String
  // 전개 예시 { input, output }[] — Character.exampleDialogue 선례대로 Json(정규화 이득 없음).
  developmentExamples Json
  // 단축어 { label, command }[] (story-level ≤20).
  shortcuts           Json
  // #26 패턴 복제 — 'all' | 'adult'(등록 탭 미성년자 적절성). 한번 설정 후 불변은 #44 DTO에서 집행.
  contentRating       String  @default("all")
  // 'public' | 'private' | 'link'(크랙 공개범위). 기본 비공개.
  visibility          String  @default("private")
  commentsClosed      Boolean @default(false)

  // ownerContext 이중축(Character 패턴 복제) — 로그인 userId / 비로그인 browserId.
  browserId String?
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])

  startSettings StartSetting[]
  sessions      StorySession[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([browserId]) // 내 스토리 목록
  @@index([userId]) // 계정 소유 스토리 목록
  @@index([visibility, updatedAt]) // 공개 스토리 목록(최신순)
}

// 분기 시나리오 단위. 스탯·엔딩이 이 단위로 스코프된다(시작설정별 스탯 ≤7, 엔딩 ≤10).
model StartSetting {
  id               String  @id @default(cuid())
  storyId          String
  story            Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  name             String
  prologue         String
  startSituation   String
  playGuide        String? // AI 비기억, 사용자에게만 보이는 가이드
  // 추천 첫 답변 string[] (≤3).
  suggestedReplies Json

  stats   Stat[]
  endings Ending[]

  createdAt DateTime @default(now())

  @@index([storyId])
}

// 스탯 = 정규화 테이블(호감도류 변수). #51 엔딩 결정론 평가가 타입 안전하게 min/max clamp 읽음.
model Stat {
  id             String       @id @default(cuid())
  startSettingId String
  startSetting   StartSetting @relation(fields: [startSettingId], references: [id], onDelete: Cascade)
  name           String
  initialValue   Int
  minValue       Int
  maxValue       Int

  @@unique([startSettingId, name]) // 시작설정 내 스탯명 중복 금지
  @@index([startSettingId])
}

// 엔딩. condition = Json 임계값 규칙 [{stat,op,value}] AND. 먼저 충족된 1개만 트리거(priority).
model Ending {
  id             String       @id @default(cuid())
  startSettingId String
  startSetting   StartSetting @relation(fields: [startSettingId], references: [id], onDelete: Cascade)
  name           String
  condition      Json
  resultText     String
  priority       Int          @default(0) // 동시충족 시 정렬 우선순위

  @@index([startSettingId])
}

// 플레이 런타임 세션(Conversation의 스토리판). statValues = 런타임 가변 상태.
model StorySession {
  id             String  @id @default(cuid())
  storyId        String
  story          Story   @relation(fields: [storyId], references: [id], onDelete: Cascade)
  startSettingId String
  // 현재 스탯 상태 { [statName]: number } — 런타임 가변(정규화 이득 없음).
  statValues     Json
  // 도달한 엔딩 id(null=진행중). FK 아닌 약참조(Ending 삭제와 독립).
  endedWith      String?

  // ownerContext 이중축.
  browserId String?
  userId    String?
  user      User?   @relation(fields: [userId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([browserId])
  @@index([userId])
  @@index([storyId])
}
