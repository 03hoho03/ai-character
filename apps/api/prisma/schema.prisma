// #14 대화 영속화 스키마.
// 소유자 = 익명 browserId. 캐릭터당 대화 1개 = (browserId, personaId) 유니크 → 이어하기 단위.
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Conversation {
  id        String    @id @default(cuid())
  browserId String
  personaId String
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]

  // #15 장기기억 — 과거 turn 자동 요약과 그 요약에 접힌 선행 turn 수.
  summary         String?
  summarizedCount Int     @default(0)

  @@unique([browserId, personaId])
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String // 'user' | 'model' — DTO(class-validator)에서 강제
  content        String
  createdAt      DateTime     @default(now())

  @@index([conversationId, createdAt])
}

// #16 캐릭터 영속화. 소유자 = 익명 browserId. id = 클라이언트 제공(`usr-<uuid>`) → #21 로컬→DB 이전이 id 충돌 없이 이뤄진다.
// 구조화 필드(exampleDialogue/prohibitions)는 Json — Persona 형태를 그대로 보존(정규화 이득 없음).
model Character {
  id              String   @id // 클라이언트 제공 usr-<uuid>
  browserId       String
  name            String
  tagline         String
  personality     String
  speechStyle     String
  worldview       String
  greeting        String
  exampleDialogue Json     // ExampleDialogueTurn[] — { user, model }
  prohibitions    Json? // string[] | null
  isPublic        Boolean  @default(false)
  // #25 발견 필터용 분류 메타데이터(프롬프트 미주입). category=단일, tags=다중(Postgres 스칼라 배열).
  category        String?
  tags            String[] @default([])
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([browserId]) // 내 캐릭터 목록
  @@index([isPublic, updatedAt]) // 공개 캐릭터 목록(최신순)
  @@index([isPublic, category]) // #25 공개+카테고리 필터
  @@index([tags], type: Gin) // #25 tags has 필터(배열 포함 검색)
}
